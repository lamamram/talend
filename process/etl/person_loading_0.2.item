    <elementParameter field="MEMO_JAVA" name="CODE_START" value="// start part of your Java code&#xA;HashSet&lt;String> slugs = new HashSet&lt;>();"/>
    <elementParameter field="MEMO_JAVA" name="CODE_MAIN" value="String[] elements = {input_row.first_name, input_row.last_name};&#xA;&#xA;String slug = Slugyfier.unique(elements, slugs);&#xA;output_row.slug = slug;&#xA;&#xA;//mise à jour des ancien slugs avec le nouveau&#xA;slugs.add(slug);&#xA;"/>
    <elementParameter field="MEMO_JAVA" name="CODE_END" value="// end of the component, outside/closing the loop&#xA;slugs = null;"/>
